# Public
NEXT_PUBLIC_SITE_URL=https://www.aidardev.kz

# Server-only backend connection (never prefix secrets with NEXT_PUBLIC_)
BACKEND_API_URL=https://your-backend.example.com
BLOG_API_SECRET=replace-with-a-long-random-secret
BLOG_REVALIDATE_SECRET=replace-with-a-different-long-random-secret
CRON_SECRET=replace-with-vercel-cron-secret

# Optional when the backend route differs from /api/blog/cron/generate
BLOG_CRON_BACKEND_PATH=/api/blog/cron/generate

# Admin blog login: password at /admin/login sets HttpOnly cookie aidardev_admin_session
ADMIN_BLOG_PASSWORD=replace-with-admin-password
ADMIN_BLOG_SESSION_TOKEN=replace-with-a-long-random-session-token
